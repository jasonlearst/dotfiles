if ! contains $HOME/.local/bin $PATH && ! contains $HOME/.local/bin $fish_user_paths
    fish_add_path --path $HOME/.local/bin
end

if status is-interactive
    # Commands to run in interactive sessions can go here
    # fish
    if command --query fzf
        fzf --fish | source
    end
    if command --query jump
        jump shell fish | source
    end
    if command --query jj
        if test (printf '%s\n4.0.2\n%s' $FISH_VERSION $FISH_VERSION | sort -V | head -n1) = $FISH_VERSION
            and test $FISH_VERSION != "4.0.2"
            COMPLETE=fish jj | source
        end
    end
    if command --query just
        JUST_COMPLETE=fish just | source
    end
    if command --query mcfly
        mcfly init fish | source
    end
    if command --query zoxide
        zoxide init fish | source
    end
    if test -f ~/.dir_colors
        if command --query gdircolors
            eval (gdircolors -c ~/.dir_colors)
        else if command --query dircolors
            eval (dircolors -c ~/.dir_colors)
        end
    end
    if command --query direnv
        direnv hook fish | source
    end
    # enable vi mode
    set -g fish_key_bindings fish_vi_key_bindings

    # bash-style !! and !$ history expansion
    if test "$fish_key_bindings" = fish_vi_key_bindings
        bind -Minsert ! __history_previous_command
        bind -Minsert '$' __history_previous_command_arguments
    else
        bind ! __history_previous_command
        bind '$' __history_previous_command_arguments
    end
end

# Set TERM to xterm-256color when using Ghostty
if test "$TERM_PROGRAM" = "ghostty"
    set -gx TERM xterm-256color
end

{{- if eq .chezmoi.os "darwin" }}
test -e {$HOME}/.iterm2_shell_integration.fish ; and source {$HOME}/.iterm2_shell_integration.fish
{{- end }}

# 1Password SSH agent — SSH_AUTH_SOCK per platform.
#   macOS:  ~/.1password/agent.sock is a chezmoi-managed symlink into the
#           1Password Group Container (see dot_1password/symlink_agent.sock.tmpl).
#   Linux:  1Password Linux app creates the socket directly at
#           ~/.1password/agent.sock.
#   WSL:    requires npiperelay + socat forwarding from Windows; see
#           https://developer.1password.com/docs/ssh/agent/wsl-windows
{{- if .isWSL }}
# Uncomment after configuring npiperelay+socat (point at the relayed socket):
# set -gx SSH_AUTH_SOCK $HOME/.ssh/wsl-1password-agent.sock
{{- else }}
if test -S ~/.1password/agent.sock
    set -gx SSH_AUTH_SOCK ~/.1password/agent.sock
end
{{- end }}

# SOPS age key on demand: sops 3.11+ runs SOPS_AGE_KEY_CMD whenever it needs
# the key, so no script or per-invocation export is required. The value is only
# an op:// reference, not a secret. CI sets SOPS_AGE_KEY/_FILE directly instead.
if command --query op
    set -gx SOPS_AGE_KEY_CMD "op read 'op://Personal/Infra - SOPS age Key/credential'"
end

# bat as the man pager (bat is installed via .chezmoiexternal.toml)
set -gx MANROFFOPT "-c"
set -gx MANPAGER "sh -c 'col -bx | bat -l man -p'"

# Helpers for !! / !$ bindings set up in the is-interactive block above
function __history_previous_command
    switch (commandline -t)
    case "!"
        commandline -t $history[1]
        commandline -f repaint
    case "*"
        commandline -i !
    end
end

function __history_previous_command_arguments
    switch (commandline -t)
    case "!"
        commandline -t ""
        commandline -f history-token-search-backward
    case "*"
        commandline -i '$'
    end
end

# history with timestamps
function history
    builtin history --show-time='%F %T '
end

function backup --argument filename
    cp $filename $filename.bak
end

function copy
    set count (count $argv | tr -d \n)
    if test "$count" = 2; and test -d "$argv[1]"
        set from (echo $argv[1] | trim-right /)
        set to (echo $argv[2])
        command cp -r $from $to
    else
        command cp $argv
    end
end

