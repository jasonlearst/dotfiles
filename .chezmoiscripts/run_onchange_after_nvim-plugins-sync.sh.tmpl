#!/bin/bash
#
# Sync lazy.nvim plugins whenever the Neovim config changes. The hash line
# below ties this script to init.lua so run_onchange_ re-fires on config
# edits. `Lazy! sync` installs/updates/cleans headlessly; lazy also
# auto-installs on first interactive launch, so this just pre-warms it.
#
# Ordering: chezmoi runs after_ scripts alphabetically by target path. The
# "nvim-plugins-sync" name (no "install-" prefix) sorts after
# "linux/install-neovim.sh" so bob has installed nvim before we sync here.
# Keep the guard below as defense-in-depth if that install was skipped.
#
# init.lua hash: {{ include "dot_config/nvim/init.lua" | sha256sum }}

set -eufo pipefail

export PATH="$HOME/.local/bin:$PATH"

if ! command -v nvim >/dev/null 2>&1; then
    echo "nvim not installed; skipping plugin sync."
    exit 0
fi

echo "Syncing lazy.nvim plugins..."
nvim --headless "+Lazy! sync" +qa || true
