{{- /*
  ~/.ssh/config — personal infrastructure host aliases.

  IdentityAgent gating — we only emit `IdentityAgent ~/.1password/agent.sock`
  when 1Password's SSH agent is actually present locally:
    - darwin: assumed (chezmoi manages the symlink into the Group Container).
    - linux (non-WSL): emit only if ~/.1password/agent.sock exists at apply
      time — checked via the `stat` template func. This keeps Linux servers
      without 1Password clean: emitting IdentityAgent there would override
      the forwarded SSH_AUTH_SOCK and break agent forwarding from the Mac.
    - WSL: skipped (forwarded socket lives elsewhere; see config.fish.tmpl).

  The github.com personal-key entry is additionally gated on .isWork so work
  machines don't try to use the personal key.
*/ -}}
{{- $hasOnePasswordAgent := false -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $hasOnePasswordAgent = true -}}
{{- else if and (eq .chezmoi.os "linux") (not .isWSL) -}}
{{-   if stat (joinPath .chezmoi.homeDir ".1password" "agent.sock") -}}
{{-     $hasOnePasswordAgent = true -}}
{{-   end -}}
{{- end -}}
Include ~/.colima/ssh_config

Host jason-um700.learst.net
  HostName jason-um700.learst.net
  User jason
{{- if $hasOnePasswordAgent }}
  IdentityAgent ~/.1password/agent.sock
{{- end }}
  ForwardAgent yes

Host 192.168.171.20
  HostName 192.168.171.20

Host 50.116.48.155
  HostName 50.116.48.155

Host apps1.lan.bigjay517.com
  HostName apps1.lan.bigjay517.com
  User pi

Host github.com
{{- if and (eq .chezmoi.os "darwin") (not .isWork) }}
  IdentityFile ~/.ssh/personal-ssh-key.pub
  IdentitiesOnly yes
{{- end }}

Host *
{{- if $hasOnePasswordAgent }}
  IdentityAgent ~/.1password/agent.sock
{{- end }}

Host nixos.learst.net
  ForwardAgent yes

Host *.learst.net
  ForwardAgent yes

Host *.banded-delta.ts.net
  ForwardAgent yes
