{{- /*
  ~/.ssh/config — personal infrastructure host aliases.

  The IdentityAgent / IdentityFile lines below assume 1Password's SSH
  agent is running locally (and the personal-ssh-key.pub is on disk),
  so they are gated on darwin. On Linux servers without 1Password we
  must NOT emit IdentityAgent — it overrides the forwarded
  SSH_AUTH_SOCK and breaks agent forwarding from the Mac. The
  github.com personal-key entry is additionally gated on .isWork so
  work machines don't try to use the personal key.

  When 1Password is installed on a Linux desktop, replace the
  `eq .chezmoi.os "darwin"` predicate with something like
  `.has1Password` (a new flag — currently in the IMPROVEMENTS backlog).
*/ -}}
Include ~/.colima/ssh_config

Host jason-um700.learst.net
  HostName jason-um700.learst.net
  User jason
{{- if eq .chezmoi.os "darwin" }}
  IdentityAgent ~/.1password/agent.sock
{{- end }}
  ForwardAgent yes

Host 192.168.171.20
  HostName 192.168.171.20

Host 50.116.48.155
  HostName 50.116.48.155

Host apps1.lan.bigjay517.com
  HostName apps1.lan.bigjay517.com
  User pi

Host github.com
{{- if and (eq .chezmoi.os "darwin") (not .isWork) }}
  IdentityFile ~/.ssh/personal-ssh-key.pub
  IdentitiesOnly yes
{{- end }}

Host *
{{- if eq .chezmoi.os "darwin" }}
  IdentityAgent ~/.1password/agent.sock
{{- end }}

Host nixos.learst.net
  ForwardAgent yes

Host *.learst.net
  ForwardAgent yes

Host *.banded-delta.ts.net
  ForwardAgent yes
